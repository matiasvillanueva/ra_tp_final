```{r funciones-auxiliares, include=FALSE}
# ============================================================
# FUNCIONES AUXILIARES
# ============================================================
press <- function(modelo) {
  e <- resid(modelo); h <- hatvalues(modelo); sum((e / (1 - h))^2)
}
cme  <- function(modelo) mean(resid(modelo)^2)
rmse <- function(obs, pred) sqrt(mean((obs - pred)^2))
mae  <- function(obs, pred) mean(abs(obs - pred))
mse  <- function(obs, pred) mean((obs - pred)^2)
```

