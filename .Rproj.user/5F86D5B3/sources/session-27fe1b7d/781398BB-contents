# Consigna II: Regularización y Predicción

## Ridge (II.1) y Lasso (II.2)

```{r ridge-lasso, include=FALSE}
# ============================================================
# MATRICES Y AJUSTE RIDGE / LASSO CON CV
# ============================================================
form_ganador <- formula(modelo_ganador)

x_train <- model.matrix(form_ganador, data = train)[, -1]
y_train <- train$ingreso_ocup
x_test  <- model.matrix(form_ganador, data = test)[, -1]
y_test  <- test$ingreso_ocup

pred_mco <- predict(modelo_ganador, newdata = test)

# Ridge
set.seed(123)
cv_ridge  <- cv.glmnet(x_train, y_train, alpha = 0, nfolds = 10, standardize = TRUE)
ridge_mod <- glmnet(x_train, y_train, alpha = 0,
                    lambda = cv_ridge$lambda.min, standardize = TRUE)

# Grafico CV Ridge (disponible en sesión)
plot(cv_ridge, main = "Validacion cruzada - Ridge")
abline(v = log(cv_ridge$lambda.min), col = "red", lty = 2)

# Lasso
set.seed(123)
cv_lasso  <- cv.glmnet(x_train, y_train, alpha = 1, nfolds = 10, standardize = TRUE)
lasso_mod <- glmnet(x_train, y_train, alpha = 1,
                    lambda = cv_lasso$lambda.min, standardize = TRUE)

# Grafico CV Lasso (disponible en sesión)
plot(cv_lasso, main = "Validacion cruzada - Lasso")
abline(v = log(cv_lasso$lambda.min), col = "red", lty = 2)

# Coeficientes
print(coef(ridge_mod))
print(coef(lasso_mod))
n_nulos_lasso <- sum(coef(lasso_mod) != 0)
cat("Coeficientes no nulos Lasso:", n_nulos_lasso, "\n")

# Predicciones
pred_ridge <- as.numeric(predict(ridge_mod, s = cv_ridge$lambda.min, newx = x_test))
pred_lasso <- as.numeric(predict(lasso_mod, s = cv_lasso$lambda.min, newx = x_test))

resultados_pred <- tibble(
  Modelo = c("MCO", "Ridge", "Lasso"),
  RMSE   = c(rmse(y_test, pred_mco), rmse(y_test, pred_ridge), rmse(y_test, pred_lasso)),
  MAE    = c(mae(y_test, pred_mco),  mae(y_test, pred_ridge),  mae(y_test, pred_lasso)),
  MSE    = c(mse(y_test, pred_mco),  mse(y_test, pred_ridge),  mse(y_test, pred_lasso))
) %>% arrange(RMSE)

modelo_predictivo_ganador <- resultados_pred$Modelo[1]
pred_best <- switch(modelo_predictivo_ganador,
  "MCO" = pred_mco, "Ridge" = pred_ridge, "Lasso" = pred_lasso)

# Grafico comparativo métricas (disponible en sesión)
resultados_pred_long <- resultados_pred %>%
  pivot_longer(cols = c(RMSE, MAE, MSE), names_to = "Metrica", values_to = "Valor")
ggplot(resultados_pred_long, aes(x = Modelo, y = Valor, fill = Modelo)) +
  geom_col(show.legend = FALSE) +
  facet_wrap(~ Metrica, scales = "free_y") +
  labs(title = "Desempeño predictivo en test", x = "Modelo", y = "Error") +
  theme_minimal()
```

**Ridge** (α = 0) fue ajustado con λ seleccionado por CV k-fold (10 folds): **λ_opt = `r round(cv_ridge$lambda.min, 2)`**. Contrae todos los coeficientes hacia cero sin eliminar variables — reduce varianza a cambio de introducir sesgo. Los signos se mantienen iguales a MCO.

**Lasso** (α = 1) fue ajustado con **λ_opt = `r round(cv_lasso$lambda.min, 4)`**. A diferencia de Ridge, llevó algunos coeficientes exactamente a cero (ej. `educ_catPrimario`, `ant_laboral1 a 5 años`), reteniendo **`r n_nulos_lasso` coeficientes no nulos** — modelo más parsimonioso que MCO.

